        "livros = []\n",
        "\n",
        "\n",
        "def criar_livro(titulo, autor, ano, codigo):\n",
        "    return {\n",
        "        \"titulo\": titulo,\n",
        "        \"autor\": autor,\n",
        "        \"ano\": ano,\n",
        "        \"codigo\": codigo,\n",
        "        \"status\": \"disponivel\"\n",
        "    }\n",
        "\n",
        "\n",
        "def ordenar():\n",
        "    for i in range(1, len(livros)):\n",
        "        atual = livros[i]\n",
        "        j = i - 1\n",
        "        while j >= 0 and livros[j][\"titulo\"].lower() > atual[\"titulo\"].lower():\n",
        "            livros[j + 1] = livros[j]\n",
        "            j -= 1\n",
        "        livros[j + 1] = atual\n",
        "\n",
        "\n",
        "def buscar_codigo(cod):\n",
        "    for i in range(len(livros)):\n",
        "        if livros[i][\"codigo\"] == cod:\n",
        "            return livros[i]\n",
        "    return None\n",
        "\n",
        "\n",
        "def mostrar_livro(l):\n",
        "    status = \"Disponivel\"\n",
        "    if l[\"status\"] == \"emprestado\":\n",
        "        status = \"Emprestado\"\n",
        "    print(\"Codigo: \" + l[\"codigo\"] + \" | Titulo: \" + l[\"titulo\"] + \" | Autor: \" + l[\"autor\"] + \" | Ano: \" + str(l[\"ano\"]) + \" | Status: \" + status)\n",
        "\n",
        "\n",
        "def cadastrar():\n",
        "    print(\"\\n-- Cadastrar livro --\")\n",
        "    titulo = input(\"Titulo: \")\n",
        "    autor = input(\"Autor: \")\n",
        "\n",
        "    ano = 0\n",
        "    while True:\n",
        "        try:\n",
        "            ano = int(input(\"Ano: \"))\n",
        "            break\n",
        "        except:\n",
        "            print(\"Digite um numero valido\")\n",
        "\n",
        "    codigo = input(\"Codigo: \")\n",
        "\n",
        "    if buscar_codigo(codigo) != None:\n",
        "        print(\"Ja existe um livro com esse codigo\")\n",
        "        return\n",
        "\n",
        "    novo = criar_livro(titulo, autor, ano, codigo)\n",
        "    livros.append(novo)\n",
        "    ordenar()\n",
        "    print(\"Livro cadastrado!\")\n",
        "\n",
        "\n",
        "def consultar():\n",
        "    print(\"\\n-- Consultar livro --\")\n",
        "    print(\"1 - Por codigo\")\n",
        "    print(\"2 - Por autor\")\n",
        "    op = input(\"Opcao: \")\n",
        "\n",
        "    if op == \"1\":\n",
        "        cod = input(\"Codigo: \")\n",
        "        l = buscar_codigo(cod)\n",
        "        if l == None:\n",
        "            print(\"Livro nao encontrado\")\n",
        "            return\n",
        "        mostrar_livro(l)\n",
        "        return\n",
        "\n",
        "    if op == \"2\":\n",
        "        autor = input(\"Autor: \")\n",
        "        encontrou = False\n",
        "        for i in range(len(livros)):\n",
        "            if livros[i][\"autor\"].lower() == autor.lower():\n",
        "                mostrar_livro(livros[i])\n",
        "                encontrou = True\n",
        "        if not encontrou:\n",
        "            print(\"Livro nao encontrado\")\n",
        "        return\n",
        "\n",
        "    print(\"Opcao invalida\")\n",
        "\n",
        "\n",
        "def alterar():\n",
        "    print(\"\\n-- Alterar dados --\")\n",
        "    cod = input(\"Codigo do livro: \")\n",
        "    l = buscar_codigo(cod)\n",
        "\n",
        "    if l == None:\n",
        "        print(\"Livro nao encontrado\")\n",
        "        return\n",
        "\n",
        "    mostrar_livro(l)\n",
        "\n",
        "    novo_titulo = input(\"Novo titulo (enter pra manter): \")\n",
        "    if novo_titulo != \"\":\n",
        "        l[\"titulo\"] = novo_titulo\n",
        "\n",
        "    novo_autor = input(\"Novo autor (enter pra manter): \")\n",
        "    if novo_autor != \"\":\n",
        "        l[\"autor\"] = novo_autor\n",
        "\n",
        "    novo_ano = input(\"Novo ano (enter pra manter): \")\n",
        "    if novo_ano != \"\":\n",
        "        try:\n",
        "            l[\"ano\"] = int(novo_ano)\n",
        "        except:\n",
        "            print(\"Ano invalido, mantendo o anterior\")\n",
        "\n",
        "    ordenar()\n",
        "    print(\"Dados atualizados!\")\n",
        "\n",
        "\n",
        "def remover():\n",
        "    print(\"\\n-- Remover livro --\")\n",
        "    cod = input(\"Codigo: \")\n",
        "    l = buscar_codigo(cod)\n",
        "\n",
        "    if l == None:\n",
        "        print(\"Livro nao encontrado\")\n",
        "        return\n",
        "\n",
        "    livros.remove(l)\n",
        "    print(\"Livro removido\")\n",
        "\n",
        "\n",
        "def listar():\n",
        "    print(\"\\n-- Lista de livros --\")\n",
        "    if len(livros) == 0:\n",
        "        print(\"Nenhum livro cadastrado\")\n",
        "        return\n",
        "    for i in range(len(livros)):\n",
        "        print(livros[i][\"titulo\"] + \" (\" + str(livros[i][\"ano\"]) + \")\")\n",
        "\n",
        "\n",
        "def emprestimo():\n",
        "    print(\"\\n-- Emprestimo --\")\n",
        "    cod = input(\"Codigo: \")\n",
        "    l = buscar_codigo(cod)\n",
        "\n",
        "    if l == None:\n",
        "        print(\"Livro nao encontrado\")\n",
        "        return\n",
        "\n",
        "    if l[\"status\"] == \"emprestado\":\n",
        "        print(\"Livro ja emprestado\")\n",
        "        return\n",
        "\n",
        "    l[\"status\"] = \"emprestado\"\n",
        "    print(\"Emprestimo realizado\")\n",
        "\n",
        "\n",
        "def devolucao():\n",
        "    print(\"\\n-- Devolucao --\")\n",
        "    cod = input(\"Codigo: \")\n",
        "    l = buscar_codigo(cod)\n",
        "\n",
        "    if l == None:\n",
        "        print(\"Livro nao encontrado\")\n",
        "        return\n",
        "\n",
        "    if l[\"status\"] == \"disponivel\":\n",
        "        print(\"Livro ja esta disponivel\")\n",
        "        return\n",
        "\n",
        "    l[\"status\"] = \"disponivel\"\n",
        "    print(\"Devolucao registrada\")\n",
        "\n",
        "\n",
        "def menu():\n",
        "    print(\"\\n=== Biblioteca ===\")\n",
        "    print(\"1 - Cadastrar livro\")\n",
        "    print(\"2 - Consultar livro\")\n",
        "    print(\"3 - Alterar dados\")\n",
        "    print(\"4 - Remover livro\")\n",
        "    print(\"5 - Listar todos\")\n",
        "    print(\"6 - Emprestimo\")\n",
        "    print(\"7 - Devolucao\")\n",
        "    print(\"8 - Sair\")\n",
        "    op = input(\"Opcao: \")\n",
        "    return op\n",
        "\n",
        "\n",
        "while True:\n",
        "    op = menu()\n",
        "\n",
        "    if op == \"1\":\n",
        "        cadastrar()\n",
        "        continue\n",
        "    if op == \"2\":\n",
        "        consultar()\n",
        "        continue\n",
        "    if op == \"3\":\n",
        "        alterar()\n",
        "        continue\n",
        "    if op == \"4\":\n",
        "        remover()\n",
        "        continue\n",
        "    if op == \"5\":\n",
        "        listar()\n",
        "        continue\n",
        "    if op == \"6\":\n",
        "        emprestimo()\n",
        "        continue\n",
        "    if op == \"7\":\n",
        "        devolucao()\n",
        "        continue\n",
        "    if op == \"8\":\n",
        "        print(\"Saindo...\")\n",
        "        break\n",
        "    print(\"Opcao invalida\")"
